# ------------------------------------------------------------------------------
# APEX CONSTRUCTION - Environment Configuration Example
# ------------------------------------------------------------------------------
# Copy this file to .env and adjust the values as needed.
# Note: When DEBUG=True, most of these have safe defaults for local dev.
# ------------------------------------------------------------------------------

# Core Django Settings
DEBUG=True
SECRET_KEY=django-insecure-replace-this-with-a-real-key-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,.yourdomain.com

# Database Configuration
# Format: postgres://USER:PASSWORD@HOST:PORT/NAME
# This is REQUIRED when DEBUG=False
DATABASE_URL=postgres://db_user:db_password@localhost:5432/construction_db

# Optional: Email Settings
# EMAIL_URL=smtp://user:password@smtp.mailtrap.io:2525

# environment ---PROD | DEV
ENVIRONMENT=DEV 